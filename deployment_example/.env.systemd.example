DJANGO_HOST=127.0.0.1
DJANGO_PORT=8000
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1

DJANGO_SECRET_KEY_FILE=/run/secrets/lx-annotate/django-secret-key
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=lx_annotate
DJANGO_DB_USER=lx_annotate
DJANGO_DB_PASSWORD_FILE=/run/secrets/lx-annotate/db-password
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432

OIDC_RP_CLIENT_ID=lx-annotate-frontend
DJANGO_KEYCLOAK_CLIENT_SECRET_FILE=/run/secrets/lx-annotate/oidc-client-secret

HTTP_PROTOCOL=https
BASE_URL=https://example.com
TIME_ZONE=UTC
CENTER_NAME=LX Annotate
LX_ANNOTATE_DEFAULT_CENTER=lx-annotate-center
ENDOREG_DEPLOYMENT_ROLE=standalone

LX_ANNOTATE_ENCRYPTED_DATA_DIR=/var/lib/lx-annotate/data
LX_ANNOTATE_MASTER_KEY_FILE=/run/secrets/lx-annotate/master-key
XDG_DATA_HOME=/var/lib/lx-annotate
DJANGO_STATIC_ROOT=/var/lib/lx-annotate/staticfiles
WORKING_DIR=/home/lx-annotate/lx-annotate-wheel
HOME_DIR=/home/lx-annotate/lx-annotate-wheel
ASSET_DIR=/home/lx-annotate/lx-annotate-wheel/assets

ENFORCE_AUTH=0
RUN_VIDEO_TESTS=0
SKIP_EXPENSIVE_TESTS=1

VITE_ENABLE_DEBUG=false

TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata
PYTORCH_ALLOC_CONF=expandable_segments:True
