DJANGO_SETTINGS_MODULE=lx_annotate.settings.settings_prod
DJANGO_ENV=production
DJANGO_DEBUG=False

DJANGO_HOST=127.0.0.1
DJANGO_PORT=8000
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1

DJANGO_SECRET_KEY=replace-me
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=lx_annotate
DJANGO_DB_USER=lx_annotate
DJANGO_DB_PASSWORD=replace-me
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432

OIDC_RP_CLIENT_ID=lx-annotate-frontend
OIDC_RP_CLIENT_SECRET=replace-me

HTTP_PROTOCOL=https
BASE_URL=https://example.com
STATIC_URL=/static/
MEDIA_URL=/media/
TIME_ZONE=UTC
CENTER_NAME=LX Annotate

LX_ANNOTATE_DATA_DIR=/var/lib/lx-annotate/data
XDG_DATA_HOME=/var/lib/lx-annotate
DJANGO_STATIC_ROOT=/var/lib/lx-annotate/staticfiles
WORKING_DIR=/var/lib/lx-annotate
HOME_DIR=/var/lib/lx-annotate
STORAGE_DIR=/var/lib/lx-annotate/storage
EXPORT_OUTPUT_DIR=/var/lib/lx-annotate/exports
ASSET_DIR=/var/lib/lx-annotate/assets

ENFORCE_AUTH=0
RUN_VIDEO_TESTS=0
SKIP_EXPENSIVE_TESTS=1

VITE_API_BASE_URL=https://example.com
VITE_API_PREFIX=api/
VITE_FINDINGS_BACKEND=endoreg
VITE_ENABLE_DEBUG=false
VITE_KEYCLOAK_URL=https://keycloak.endo-reg.net
VITE_KEYCLOAK_REALM=lx-realm
VITE_KEYCLOAK_CLIENT_ID=lx-annotate-frontend

TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata
PYTORCH_ALLOC_CONF=expandable_segments:True
