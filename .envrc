#!/usr/bin/env bash

eval "$(devenv direnvrc)"

# devenv 1.11.1 currently lets secretspec's human-readable report reach
# `print-dev-env` stdout in this repo. direnv then evals that prose as shell
# code. Keep the normal devenv integration, but strip everything before the
# first real shell statement.
use_devenv() {
  _nix_direnv_preflight

  export DEVENV_CMDLINE="$*"

  local devenv_cmd=("${DEVENV_BIN}")
  if (( $# > 0 )); then
    devenv_cmd+=("$@")
  fi

  watch_file .envrc devenv.nix devenv.yaml devenv.lock

  local env
  local print_cmd=("${devenv_cmd[@]}" "print-dev-env")
  if ! env=$("${print_cmd[@]}" | sed -n '/^unset shellHook$/,$p'); then
    log_error "failed to build the devenv environment. devenv.nix may contain errors. see above."
    exit 0
  fi

  if [[ -z "$env" ]]; then
    log_error "devenv print-dev-env did not produce shell exports."
    exit 0
  fi

  _nix_import_env "$env"
}

use devenv
